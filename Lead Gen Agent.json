    {
      "parameters": {
        "jsCode": "// 1. Prepare the input data for matching.\n// Converts the input JSON data into a single, searchable string.\nconst input = JSON.stringify($input.first().json.data) || '';\n\n// 2. Define Regex Patterns for all desired fields (with improvements).\n\n// 📧 Email Regex: Simpler and more robust pattern for standard email formats.\nconst emailRegex = /\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,6}\\b/g;\n\n// 📞 Phone Number Regex: Flexible for UK/International formats, allowing spaces,\n// hyphens, and optional international codes (e.g., +44 1234 567890 or 01234 567890).\n// This pattern is more forgiving than the previous one.\nconst phoneRegex = /(?:\\+?44|0)[\\s.-]?\\d{3,5}[\\s.-]?\\d{4,7}|(?:\\+\\d{1,3}[\\s.-]?)?\\d{2,}[\\s.-]?\\d{2,}[\\s.-]?\\d{4,}/g;\n\n// 💰 Currency Amounts: Focuses on specific currency formats and large numbers, \n// using a lookbehind to better isolate currency.\n// Note: JavaScript in some environments doesn't support lookbehinds, so this \n// version uses a broad pattern followed by post-processing.\nconst revenueRegex = /([£€$]\\s*[\\d,.]+(?:\\s*(?:M|K|B)\\b)?)|(\\b[\\d,]+\\s*(?:M|K|B)\\b)/gi;\n\n// 📈 Sales Units: More specific for a typical number of sales units (2-6 digits)\n// but excludes common number patterns that are likely year or revenue.\n// This still needs a manual check against the actual content for best results.\nconst salesUnitRegex = /\\b\\d{2,6}\\b/g;\n\n// 3. Extract all matches.\nconst emailsRaw = input.match(emailRegex) || [];\nconst phonesRaw = input.match(phoneRegex) || [];\nconst revenueRaw = input.match(revenueRegex) || [];\nconst salesRaw = input.match(salesUnitRegex) || [];\n\n// 4. Sanitize and Clean the extracted data.\n// Use Set to ensure unique values and clean up any potential noise.\nconst emails = [...new Set(emailsRaw.map(e => e.trim().toLowerCase()))];\n\n// Filter out common unwanted matches like years (2022, 2015, etc.) and small numbers\n// before removing duplicates. You'll need to adjust this filtering based on your noise.\nconst phones = [...new Set(phonesRaw.map(p => p.trim()))].filter(p => !p.includes('19') && !p.includes('20') && p.length > 7);\n\n// Basic cleanup for revenue values\nconst revenue = [...new Set(revenueRaw.map(r => r.trim()))];\n\n// Filter sales units to exclude single digits and years, ensuring it's a number.\nconst sales = [...new Set(salesRaw)]\n    .filter(s => s.length > 2 && !/20\\d{2}/.test(s));\n\n\n// 5. Return the results.\nreturn {\n  json: {\n    emails: emails,\n    phones: phones,\n    revenue: revenue,\n    sales_units: sales\n  }\n};"
      },
