    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const raw = item.json;\n\n  // 1. Helper to pick the first valid item from an array\n  const getFirst = (val) => (Array.isArray(val) && val.length > 0 ? val[0] : (typeof val === 'string' ? val : null));\n\n  // 2. Email Collector Logic\n  let emailList = [];\n  if (raw.email) emailList.push(raw.email);\n  if (Array.isArray(raw.emails)) emailList.push(...raw.emails);\n  if (Array.isArray(raw.leadsEnrichment)) {\n    raw.leadsEnrichment.forEach(lead => {\n      if (lead.email) emailList.push(lead.email);\n      if (Array.isArray(lead.emails)) emailList.push(...lead.emails);\n    });\n  }\n  const uniqueEmails = [...new Set(emailList.filter(e => typeof e === 'string' && e.includes('@')))];\n\n  return {\n    json: {\n      company_name: raw.title || raw.name || raw.company_name || null,\n      category: raw.category || raw.categoryName || raw.mainCategory || null,\n      address: raw.address || raw.full_address || null,\n      \n      // IMPROVED NEIGHBOURHOOD SEARCH\n      neighbourhood: raw.neighbourhood || \n                     raw.sublocality || \n                     raw.neighborhood || \n                     raw.district || \n                     (raw.location && raw.location.neighbourhood) || \n                     null,\n\n      phone: raw.phone || raw.phoneNumber ? `'${raw.phone || raw.phoneNumber}` : null,\n      email_1: uniqueEmails[0] || null,\n      email_2: uniqueEmails[1] || null,\n      email_3: uniqueEmails[2] || null,\n      website: getFirst(raw.website) || getFirst(raw.websites) || null,\n      domain: raw.domain || null,\n      facebook_url: getFirst(raw.facebookProfiles) || getFirst(raw.facebooks) || null,\n      instagram_url: getFirst(raw.instagrams) || null,\n      youtube_url: getFirst(raw.youtubes) || null,\n      tiktok_url: getFirst(raw.tiktoks) || null\n    }\n  };\n});"
      },
