    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nconst existingCompanies = allItems\n  .filter(item => item.json['Company name'])\n  .map(item => item.json['Company name']);\n\nconst loopItem = $('Loop Over Items').item.json;\n\nconst getFirst = (val) => (Array.isArray(val) && val.length > 0 ? val[0] : (typeof val === 'string' ? val : null));\n\nconst newCompanyName = (loopItem.title || loopItem.name || loopItem.company_name || '').trim().toLowerCase();\n\nconst isDuplicate = existingCompanies.some(\n  existingName => existingName?.trim().toLowerCase() === newCompanyName\n);\n\nif (isDuplicate) {\n  return [{ json: { isNew: false } }];\n}\n\n// Build emails\nlet emailList = [];\nif (loopItem.email) emailList.push(loopItem.email);\nif (Array.isArray(loopItem.emails)) emailList.push(...loopItem.emails);\nif (Array.isArray(loopItem.leadsEnrichment)) {\n  loopItem.leadsEnrichment.forEach(lead => {\n    if (lead.email) emailList.push(lead.email);\n    if (Array.isArray(lead.emails)) emailList.push(...lead.emails);\n  });\n}\nconst uniqueEmails = [...new Set(emailList.filter(e => typeof e === 'string' && e.includes('@')))];\n\n// ✅ Log raw fields to debug\nconsole.log('website:', loopItem.website);\nconsole.log('websites:', loopItem.websites);\nconsole.log('Websites:', loopItem.Websites);  \nconsole.log('domain:', loopItem.domain);\nconsole.log('Domain:', loopItem.Domain);\n\nreturn [{\n  json: {\n    isNew: true,\n    \"Company name\":     loopItem.title || loopItem.name || loopItem.company_name || null,\n    \"Status\":           null,\n    \"Company category\": loopItem.category || loopItem.categoryName || loopItem.mainCategory || null,\n    \"Address\":          loopItem.address || loopItem.full_address || null,\n    \"Neighbourhood\":    loopItem.neighbourhood || loopItem.sublocality || loopItem.neighborhood || loopItem.district || (loopItem.location && loopItem.location.neighbourhood) || null,\n    \"Phone\":            (loopItem.phone || loopItem.phoneNumber) ? `'${loopItem.phone || loopItem.phoneNumber}` : null,\n    \"email_1\":          uniqueEmails[0] || null,\n    \"email_2\":          uniqueEmails[1] || null,\n    \"email_3\":          uniqueEmails[2] || null,\n\n    // ✅ Check both lowercase and uppercase variations\n    \"Websites\":         getFirst(loopItem.website) || getFirst(loopItem.websites) || \n                        getFirst(loopItem.Website) || getFirst(loopItem.Websites) || null,\n    \"Domain\":           loopItem.domain || loopItem.Domain || null,\n    \"Facebook\":         getFirst(loopItem.facebookProfiles) || getFirst(loopItem.facebooks) || \n                        getFirst(loopItem.Facebook) || null,\n    \"Instagram\":        getFirst(loopItem.instagrams) || getFirst(loopItem.Instagram) || null,\n    \"Twitter\":          getFirst(loopItem.twitters) || getFirst(loopItem.Twitter) || null,\n    \"LinkedIn\":         getFirst(loopItem.linkedIns) || getFirst(loopItem.LinkedIn) || null,\n    \"Youtube\":          getFirst(loopItem.youtubes) || getFirst(loopItem.Youtube) || null,\n    \"TikTok\":           getFirst(loopItem.tiktoks) || getFirst(loopItem.TikTok) || null\n  }\n}];"
